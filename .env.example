# =============================================================================
# NuriNamuAiChat — 환경 변수 설정 템플릿 (v4.1 Enterprise)
# 조달청 납품 보안 요건 준수
# =============================================================================
# 이 파일을 복사하여 .env 파일로 사용하세요: cp .env.example .env
# ⚠️ .env 파일은 절대 Git에 포함하지 마세요 (.gitignore 확인)
# =============================================================================

# --- [Database Configuration] ---
DB_USER=nurinamu_admin
DB_PASSWORD=your_strong_password_here_min_16chars
DB_NAME=nurinamu_chat_db
# PostgreSQL 연결 URL (암호화 또는 직접 지정)
# DATABASE_URL=postgresql://nurinamu_admin:password@localhost:5432/nurinamu_chat_db

# --- [Security Configuration] ⚠️ 필수 항목 ---
# ⚠️ API_KEY: 반드시 설정. 기본값 없음. 최소 32자 권장
API_KEY=

# ⚠️ ALLOWED_ORIGINS: 반드시 도메인을 명시. 와일드카드(*) 사용 금지
# 개발: http://localhost:3000,http://localhost:3001
# 운영 예시: https://chat.go.kr,https://api.go.kr
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting (IP당 분당 요청 제한)
RATE_LIMIT_PER_MINUTE=30/minute

# 세션 만료 시간 (분)
SESSION_TIMEOUT_MINUTES=30

# 암호화 키 (ENCRYPTED_DATABASE_URL 사용 시)
# MASTER_KEY=
# ENCRYPTED_DATABASE_URL=

# --- [LLM Providers] ---
# 기본 LLM 제공사 (local, openai, gemini, anthropic)
GLOBAL_LLM_PROVIDER=local
# 로컬 Ollama 컨테이너 또는 외부 서버 주소 (운영 환경 배포 시 필수 점검)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=
OPENAI_MAIN_MODEL=gpt-4o
OPENAI_ROUTER_MODEL=gpt-4o-mini

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Google Cloud Vertex AI (Enterprise)
GCP_PROJECT_ID=
GCP_LOCATION=asia-northeast3
GOOGLE_APPLICATION_CREDENTIALS=

# --- [Embedding Models] ---
GLOBAL_EMBEDDING_PROVIDER=local
GLOBAL_EMBEDDING_MODEL=BAAI/bge-m3
VECTOR_DB_COLLECTION=enterprise_knowledge_v3

# --- [Audit & Monitoring] ⚠️ 조달청 납품 필수 ---
# 감사 로그 활성화 (운영 환경에서는 반드시 true)
AUDIT_LOG_ENABLED=true

# --- [Monitoring & Features] ---
HIDE_DETAILED_JUDGMENT=false
GLOBAL_SEARCH_MODE=auto

# --- [File Storage] ---
# 임베딩 전용 문서 파일(PDF, MD 등) 업로드 폴더 경로
DOC_ARCHIVE_DIR=doc_archive

# --- [Metadata Tagging] ---
ENABLE_METADATA_TAGGING=false
ENABLE_QUERY_METADATA=false
TAGGING_LLM_PROVIDER=
TAGGING_LLM_MODEL=
TAGGING_CONCURRENCY=3
TAGGING_DELAY=0.5

# --- [System URLs] ---
# 백엔드 API 서버 URL (Python FastAPI)
BACKEND_URL=http://localhost:8000
# 프론트엔드 URL (Next.js)
FRONTEND_URL=http://localhost:3000
# 관리자 콘솔 URL (Streamlit)
ADMIN_URL=http://localhost:8502

# --- [Frontend Specific] ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- [Input Security Guard] ---
# 입력 보안 가드 전체 활성화 여부 (기본: true)
INPUT_GUARD_ENABLED=true
# 프롬프트 인젝션 탐지 시 요청 차단 여부 (기본: true — 반드시 활성화 권장)
INPUT_GUARD_INJECTION_BLOCK=true
# 고위험 PII(주민번호·카드번호 등) 입력 시 차단 여부 (기본: false — 마스킹 후 허용)
# true 시 해당 질문이 완전히 거부됩니다.
INPUT_GUARD_PII_BLOCK=false
# 질문 최대 길이 (기본: 2000자, 초과 시 차단)
INPUT_MAX_LENGTH=2000

# --- [AI System Prompt] ---
# 관리자가 AI의 역할과 행동 지침을 직접 설정합니다.
# 비워두면 시스템 기본 프롬프트(법률 비서 + 조문 인용 의무화)가 사용됩니다.
# Admin Dashboard > 환경 설정 > AI 시스템 프롬프트 편집에서 GUI로 수정 가능합니다.
SYSTEM_PROMPT_OVERRIDE=

# --- [Audit Log] ---
# 감사 로그에 질문 미리보기 저장 여부 (기본: false — 해시만 저장)
# true 설정 시 질문 앞 N자를 question_preview 필드에 추가 저장합니다.
# 오류 추적에 유용하나, 개인정보보호법 제3조(최소수집 원칙) 검토 후 활성화하세요.
AUDIT_STORE_QUESTION_PREVIEW=false
# 미리보기 저장 글자 수 (기본 50자)
AUDIT_QUESTION_PREVIEW_LENGTH=50

# --- [Metadata Tagging] ---
# 메타데이터 분류 LLM 신뢰도 임계값 (0.0~1.0, 기본 0.4)
# 이 값 미만이면 Rule-based 결과를 우선 적용합니다.
# 오분류가 잦으면 값을 높이고(0.6), 검색 결과가 너무 엄격하면 낮추세요(0.2).
TAGGING_CONFIDENCE_THRESHOLD=0.4

# --- [Deployment] ---
# 운영환경: production / 개발환경: development
NODE_ENV=development
